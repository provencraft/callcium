{
  "name": "@callcium/docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "bunx serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint && bun tools/lint-links.ts",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "sync": "bun run sync:reference && bun run sync:specs",
    "sync:reference": "bun run --cwd .. docs && bun tools/sync-reference.ts",
    "sync:specs": "bun tools/sync-specs.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "tools:policy:explain": "bun tools/policy-inspector/cli.ts"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "16.6.8",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-ui": "16.6.8",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "next-validate-link": "^1.6.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "postcss": "^8.5.8",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.0.18"
  }
}
