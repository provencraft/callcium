{
  "name": "@callcium/sdk",
  "version": "0.1.0",
  "description": "Build and validate Callcium policies offchain in TypeScript",
  "keywords": [
    "abi",
    "callcium",
    "ethereum",
    "evm",
    "policy",
    "smart-contracts",
    "typescript",
    "web3"
  ],
  "homepage": "https://callcium.dev",
  "bugs": "https://github.com/provencraft/callcium/issues",
  "license": "MIT",
  "author": "Seva Mihailov",
  "repository": {
    "type": "git",
    "url": "https://github.com/provencraft/callcium.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "release:patch": "npm version patch --tag-version-prefix=sdk/v",
    "release:minor": "npm version minor --tag-version-prefix=sdk/v",
    "release:major": "npm version major --tag-version-prefix=sdk/v",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typedoc": "typedoc"
  },
  "dependencies": {
    "@noble/hashes": "1.8.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "tsdown": "0.21.10",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
