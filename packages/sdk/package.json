{
  "name": "@callcium/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Callcium on-chain policy engine",
  "keywords": [
    "abi",
    "callcium",
    "ethereum",
    "evm",
    "policy",
    "smart-contracts",
    "typescript",
    "web3"
  ],
  "homepage": "https://callcium.dev",
  "bugs": "https://github.com/provencraft/callcium/issues",
  "license": "MIT",
  "author": "Seva Mihailov",
  "repository": {
    "type": "git",
    "url": "https://github.com/provencraft/callcium.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "release:patch": "npm version patch --tag-version-prefix=sdk/v",
    "release:minor": "npm version minor --tag-version-prefix=sdk/v",
    "release:major": "npm version major --tag-version-prefix=sdk/v",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "1.8.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "oxfmt": "0.42.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "tsdown": "0.21.7",
    "typescript": "6.0.2",
    "vitest": "3.2.4"
  }
}
