{
  "name": "@callcium/docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run sync && next build",
    "dev": "next dev",
    "start": "bunx serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint && bun tools/lint-links.ts",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "sync": "bun run sync:reference && bun run sync:sdk-reference && bun run sync:specs",
    "sync:reference": "bun run --cwd ../contracts docs && bun tools/sync-reference.ts",
    "sync:sdk-reference": "bun run --cwd ../sdk typedoc && bun tools/sync-sdk-reference.ts",
    "sync:specs": "bun tools/sync-specs.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "tools:policy:explain": "bun tools/policy-inspector/cli.ts"
  },
  "dependencies": {
    "@callcium/sdk": "workspace:*",
    "@icons-pack/react-simple-icons": "13.13.0",
    "@orama/orama": "3.1.18",
    "@radix-ui/react-select": "2.2.6",
    "fumadocs-core": "16.8.2",
    "fumadocs-mdx": "14.3.1",
    "fumadocs-typescript": "5.2.6",
    "fumadocs-ui": "16.8.2",
    "lucide-react": "0.576.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "viem": "2.48.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/mdx": "2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "next-validate-link": "1.6.5",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "postcss": "8.5.10",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "unified": "11.0.5",
    "unist-util-remove": "4.0.0",
    "unist-util-visit": "5.1.0",
    "vitest": "4.1.5"
  }
}
